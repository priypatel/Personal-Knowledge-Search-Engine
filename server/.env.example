# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/knowbase

# Server
PORT=5000
NODE_ENV=development

# LLM Providers — add at least ONE key.
# System auto-routes requests: Groq → DeepSeek → Gemini (priority order).
# On rate-limit (429) the provider cools down 60s and the next is tried.

# Groq (fastest, free 30 RPM) — https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# DeepSeek (free tier, OpenAI-compatible) — https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Google Gemini Flash (free 15 RPM / 1500 RPD) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Auth — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_min_32_chars_different_from_above

# Email — Resend (free 3,000/month) — https://resend.com
RESEND_API_KEY=re_your_resend_api_key_here
# In dev: use onboarding@resend.dev (only delivers to your Resend account email)
# In prod: use your verified domain e.g. noreply@yourdomain.com
FROM_EMAIL=onboarding@resend.dev

# CORS — set to your Vercel client URL in production
CLIENT_URL=http://localhost:5173
